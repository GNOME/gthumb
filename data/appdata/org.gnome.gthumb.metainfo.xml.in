<?xml version="1.0" encoding="UTF-8"?>
<!-- Copyright 2014-2026 Paolo Bacchilega <paobac@src.gnome.org> -->
<component type="desktop-application">
  <id>org.gnome.gthumb</id>
  <replaces>
    <id>org.gnome.gThumb.desktop</id>
  </replaces>
  <provides>
    <id>org.gnome.gThumb.desktop</id>
  </provides>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-2.0+</project_license>

  <name>Thumbnails</name>
  <summary>View and organize your images</summary>
  <developer id="org.gnome">
    <name translatable="no">Paolo Bacchilega</name>
  </developer>
  <description>
    <p>
      Image viewer, editor, browser and organizer.
    </p>
    <p>
      View images: PNG, JPEG, WEBP, SVG, JXL, HEIF, AVIF, TIFF, GIF, RAW.
    </p>
    <p>
      Edit images: scale, rotate and crop images, change contrast, brightness and saturation, as well as other color transformations.
    </p>
    <p>
      View and edit embedded metadata: EXIF, IPTC and XMP.
    </p>
    <p>
      File manager operations: copy, move, rename and delete files and folders, execute scripts on the selected files.
    </p>
    <p>
      Image specific tools:
    </p>
    <ul>
      <li>JPEG lossless transformations</li>
      <li>Image resize</li>
      <li>Format conversion</li>
      <li>Slideshow</li>
      <li>Setting an image as desktop background</li>
    </ul>
    <p>
      Add comments and other metadata to images, organize images in catalogs
      and catalogs in libraries, search for images and save the result as
      a catalog.
    </p>
  </description>

  <launchable type="desktop-id">org.gnome.gthumb.desktop</launchable>
  <url type="homepage">https://gitlab.gnome.org/GNOME/gthumb/</url>
  <url type="bugtracker">https://gitlab.gnome.org/GNOME/gthumb/-/issues</url>
  <url type="vcs-browser">https://gitlab.gnome.org/GNOME/gthumb/</url>
  <url type="translate">https://l10n.gnome.org/module/gthumb/</url>
  <screenshots>
    <screenshot type="default">
      <image type="source">https://gitlab.gnome.org/GNOME/gthumb/raw/master/data/appdata/browser.png</image>
      <caption>Browser</caption>
    </screenshot>
    <screenshot>
      <image type="source">https://gitlab.gnome.org/GNOME/gthumb/raw/master/data/appdata/viewer.png</image>
      <caption>Viewer</caption>
    </screenshot>
    <screenshot>
      <image type="source">https://gitlab.gnome.org/GNOME/gthumb/raw/master/data/appdata/editor.png</image>
      <caption>Editor</caption>
    </screenshot>
  </screenshots>
  <releases>
    <release version="4.0.alpha" date="2026-04-26" type="unstable">
      <description>
        <p>This release adds the following features:</p>
        <ul>
          <li>Ported to GTK4, rewritten in Vala</li>
          <li>Play WEBP and PNG animations</li>
          <li>Save as JXL</li>
          <li>Filters: allow to change the quantity of the applied filter for many filters</li>
          <li>Filters: added Censor to pixelize or blur an image area</li>
          <li>Removed web albums, contact sheet, adjust time, find duplicates</li>
        </ul>
      </description>
    </release>
    <release version="3.12.10" date="2026-02-10" type="stable">
      <description>
        Fixed potential crash.
      </description>
    </release>
    <release version="3.12.9" date="2026-01-23" type="stable">
      <description>
        <p>This release fixes the following bugs:</p>
        <ul>
          <li>Fixed compilation when lcms2 is disabled</li>
          <li>Lossless rotation: make sure to modify the orientation tags only</li>
          <li>Do not change the file modification time if the content did not change</li>
          <li>Sharpen: allow to view the image at natural size</li>
          <li>Rotation: fixed bilinear filter</li>
        </ul>
      </description>
    </release>
  </releases>
  <update_contact>paobac_at_src.gnome.org</update_contact>
  <kudos>
    <kudo>AppMenu</kudo>
    <kudo>HiDpiIcon</kudo>
    <kudo>ModernToolkit</kudo>
  </kudos>
  <translation type="gettext">gthumb</translation>

  <content_rating type="oars-1.1">
    <content_attribute id="social-info">mild</content_attribute>
    <content_attribute id="social-audio">moderate</content_attribute>
  </content_rating>
</component>
