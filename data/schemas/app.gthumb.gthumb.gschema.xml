<schemalist>
  <schema id="app.gthumb.gthumb" path="/app/gthumb/gthumb/" gettext-domain="gthumb">
    <key name="store-metadata-in-files" type="b">
      <default>true</default>
    </key>
    <key name="show-format-options" type="b">
      <default>true</default>
    </key>
    <key name="go-to-last-location" type="b">
      <default>true</default>
    </key>
    <key name="use-startup-location" type="b">
      <default>false</default>
    </key>
    <key name="startup-location" type="s">
      <default>''</default>
    </key>
    <key name="startup-current-file" type="s">
      <default>''</default>
    </key>
    <key name="reuse-active-window" type="b">
      <default>false</default>
      <description>Open files in the active window</description>
    </key>
    <key name="general-filter" type="s">
      <default>'Type::Media'</default>
    </key>
    <key name="show-hidden-files" type="b">
      <default>false</default>
    </key>
    <key name="fast-file-type" type="b">
      <default>true</default>
    </key>
    <key name="thumbnail-size" type="i">
      <default>250</default>
    </key>
    <key name="thumbnail-caption" type="s">
      <default>''</default>
    </key>
    <key name="sort-type" type="s">
      <default>'File::Name'</default>
    </key>
    <key name="sort-inverse" type="b">
      <default>false</default>
    </key>
    <key name="window-width" type="i">
      <default>1600</default>
    </key>
    <key name="window-height" type="i">
      <default>900</default>
    </key>
    <key name="maximized" type="b">
      <default>false</default>
    </key>
    <key name="sidebar-visible" type="b">
      <default>true</default>
    </key>
    <key name="sidebar-width" type="i">
      <default>300</default>
    </key>
    <key name="properties-visible" type="b">
      <default>false</default>
    </key>
    <key name="properties-width" type="i">
      <default>300</default>
    </key>
    <key name="folder-tree-sort-type" type="s">
      <default>'name'</default>
    </key>
    <key name="folder-tree-sort-inverse" type="b">
      <default>false</default>
    </key>
    <key name="open-files-in-fullscreen" type="b">
      <default>false</default>
    </key>
    <key name="last-catalog" type="s">
      <default>''</default>
    </key>
    <key name="clipboard-type" type="s">
      <default>'image/jpeg'</default>
    </key>
    <child name="terminal" schema="app.gthumb.gthumb.terminal" />
    <child name="rename" schema="app.gthumb.gthumb.rename" />
    <child name="rotate" schema="app.gthumb.gthumb.rotate" />
    <child name="resize" schema="app.gthumb.gthumb.resize" />
    <child name="convert" schema="app.gthumb.gthumb.convert" />
    <child name="print" schema="app.gthumb.gthumb.print" />
  </schema>

  <schema id="app.gthumb.gthumb.terminal" path="/app/gthumb/gthumb/terminal/" gettext-domain="gthumb">
    <key name="command" type="s">
      <default>'kgx --working-directory=%f'</default>
    </key>
  </schema>

  <enum id="app.gthumb.gthumb.GthTextTransform">
    <value nick="none" value="0"/>
    <value nick="lowercase" value="1"/>
    <value nick="uppercase" value="2"/>
  </enum>

  <schema id="app.gthumb.gthumb.rename" path="/app/gthumb/gthumb/rename/" gettext-domain="gthumb">
    <key name="template" type="s">
      <default>'####%E'</default>
    </key>
    <key name="first-index" type="i">
      <default>1</default>
    </key>
    <key name="sort-name" type="s">
      <default>'Private::Unsorted'</default>
    </key>
    <key name="reverse-order" type="b">
      <default>false</default>
    </key>
    <key name="text-transform" enum="app.gthumb.gthumb.GthTextTransform">
      <default>'none'</default>
    </key>
  </schema>

  <enum id="app.gthumb.gthumb.GthRotatedSize">
    <value nick="original" value="0"/>
    <value nick="bounding-box" value="1"/>
    <value nick="crop-borders" value="2"/>
  </enum>

  <schema id="app.gthumb.gthumb.rotate" path="/app/gthumb/gthumb/rotate/" gettext-domain="gthumb">
    <key name="background" type="s">
      <default>'#000'</default>
    </key>
    <key name="size" enum="app.gthumb.gthumb.GthRotatedSize">
      <default>'bounding-box'</default>
    </key>
  </schema>

  <enum id="app.gthumb.gthumb.GthResizeUnit">
    <value nick="pixel" value="0"/>
    <value nick="percent" value="1"/>
  </enum>

  <schema id="app.gthumb.gthumb.resize" path="/app/gthumb/gthumb/resize/" gettext-domain="gthumb">
    <key name="width" type="i">
      <default>200</default>
    </key>
    <key name="height" type="i">
      <default>200</default>
    </key>
    <key name="unit" enum="app.gthumb.gthumb.GthResizeUnit">
      <default>'pixel'</default>
    </key>
    <key name="keep-aspect-ratio" type="b">
      <default>true</default>
    </key>
    <key name="format" type="s">
      <default>''</default>
    </key>
  </schema>

  <schema id="app.gthumb.gthumb.convert" path="/app/gthumb/gthumb/convert/" gettext-domain="gthumb">
    <key name="format" type="s">
      <default>''</default>
    </key>
  </schema>

  <enum id="app.gthumb.gthumb.GthPrintUnit">
    <value nick="mm" value="0"/>
    <value nick="inch" value="1"/>
  </enum>

  <schema id="app.gthumb.gthumb.print" path="/app/gthumb/gthumb/print/" gettext-domain="gthumb">
    <key name="rows" type="i">
      <default>1</default>
    </key>
    <key name="columns" type="i">
      <default>1</default>
    </key>
    <key name="unit" enum="app.gthumb.gthumb.GthPrintUnit">
      <default>'mm'</default>
    </key>
    <key name="output-dir" type="s">
      <default>''</default>
    </key>
  </schema>
</schemalist>
