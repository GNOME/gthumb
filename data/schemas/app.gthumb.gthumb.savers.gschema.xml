<schemalist>

  <schema id="app.gthumb.gthumb.savers" path="/app/gthumb/gthumb/savers/">
    <child name="avif" schema="app.gthumb.gthumb.savers.avif" />
    <child name="jpeg" schema="app.gthumb.gthumb.savers.jpeg" />
    <child name="png" schema="app.gthumb.gthumb.savers.png" />
    <child name="tiff" schema="app.gthumb.gthumb.savers.tiff" />
    <child name="webp" schema="app.gthumb.gthumb.savers.webp" />
    <child name="jxl" schema="app.gthumb.gthumb.savers.jxl" />
  </schema>

  <schema id="app.gthumb.gthumb.savers.avif" path="/app/gthumb/gthumb/savers/avif/" gettext-domain="gthumb">
    <key name="quality" type="i">
      <default>50</default>
    </key>
    <key name="lossless" type="b">
      <default>false</default>
    </key>
  </schema>

  <schema id="app.gthumb.gthumb.savers.jpeg" path="/app/gthumb/gthumb/savers/jpeg/" gettext-domain="gthumb">
    <key name="default-ext" type="s">
      <default>'jpeg'</default>
      <description>Possible values are: jpeg, jpg.</description>
    </key>
    <key name="quality" type="i">
      <default>85</default>
    </key>
    <key name="smoothing" type="i">
      <default>0</default>
    </key>
    <key name="optimize" type="b">
      <default>true</default>
    </key>
    <key name="progressive" type="b">
      <default>false</default>
    </key>
  </schema>

  <schema id="app.gthumb.gthumb.savers.png" path="/app/gthumb/gthumb/savers/png/" gettext-domain="gthumb">
    <key name="compression-level" type="i">
      <default>6</default>
    </key>
  </schema>

  <enum id="app.gthumb.gthumb.TiffCompression">
    <value nick="none" value="0"/>
    <value nick="lossless" value="1"/>
    <value nick="jpeg" value="2"/>
  </enum>

  <schema id="app.gthumb.gthumb.savers.tiff" path="/app/gthumb/gthumb/savers/tiff/" gettext-domain="gthumb">
    <key name="default-ext" type="s">
      <default>'tiff'</default>
      <description>Possible values are: tiff, tif.</description>
    </key>
    <key name="compression" enum="app.gthumb.gthumb.TiffCompression">
      <default>'lossless'</default>
    </key>
    <key name="horizontal-resolution" type="i">
      <default>72</default>
    </key>
    <key name="vertical-resolution" type="i">
      <default>72</default>
    </key>
  </schema>

  <schema id="app.gthumb.gthumb.savers.webp" path="/app/gthumb/gthumb/savers/webp/" gettext-domain="gthumb">
    <key name="quality" type="i">
      <default>75</default>
    </key>
    <key name="method" type="i">
      <default>4</default>
    </key>
    <key name="lossless" type="b">
      <default>false</default>
    </key>
  </schema>

  <schema id="app.gthumb.gthumb.savers.jxl" path="/app/gthumb/gthumb/savers/jxl/" gettext-domain="gthumb">
    <key name="effort" type="i">
      <default>7</default>
    </key>
    <key name="distance" type="d">
      <default>1.0</default>
    </key>
    <key name="lossless" type="b">
      <default>false</default>
    </key>
  </schema>

</schemalist>
