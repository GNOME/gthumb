<schemalist>
  <schema id="org.gnome.gthumb" path="/org/gnome/gthumb/" gettext-domain="gthumb">
    <key name="store-metadata-in-files" type="b">
      <default>true</default>
    </key>
    <key name="show-format-options" type="b">
      <default>true</default>
    </key>
    <key name="home-folder" type="s">
      <default>''</default>
    </key>
    <key name="restore-session" type="b">
      <default>true</default>
    </key>
    <key name="session-location" type="s">
      <default>''</default>
    </key>
    <key name="session-current-file" type="s">
      <default>''</default>
    </key>
    <key name="reuse-active-window" type="b">
      <default>true</default>
      <description>Open files in the active window</description>
    </key>
    <key name="general-filter" type="s">
      <default>'Type::Media'</default>
    </key>
    <key name="show-hidden-files" type="b">
      <default>false</default>
    </key>
    <key name="thumbnail-size" type="i">
      <default>256</default>
    </key>
    <key name="thumbnail-caption" type="s">
      <default>''</default>
    </key>
    <key name="sort-type" type="s">
      <default>'Time::Modified'</default>
    </key>
    <key name="sort-inverse" type="b">
      <default>true</default>
    </key>
    <key name="window-width" type="i">
      <default>1600</default>
    </key>
    <key name="window-height" type="i">
      <default>900</default>
    </key>
    <key name="maximized" type="b">
      <default>false</default>
    </key>
    <key name="sidebar-visible" type="b">
      <default>true</default>
    </key>
    <key name="sidebar-width" type="i">
      <default>350</default>
    </key>
    <key name="properties-visible" type="b">
      <default>false</default>
    </key>
    <key name="properties-width" type="i">
      <default>350</default>
    </key>
    <key name="folder-tree-sort-type" type="s">
      <default>'name'</default>
    </key>
    <key name="folder-tree-sort-inverse" type="b">
      <default>false</default>
    </key>
    <key name="open-files-in-fullscreen" type="b">
      <default>false</default>
    </key>
    <key name="last-catalog" type="s">
      <default>''</default>
    </key>
    <key name="add-to-catalog-show-destination" type="b">
      <default>true</default>
    </key>
    <key name="clipboard-type" type="s">
      <default>'image/jpeg'</default>
    </key>
    <key name="last-extension" type="s">
      <default>''</default>
    </key>
    <child name="terminal" schema="org.gnome.gthumb.terminal" />
    <child name="rename" schema="org.gnome.gthumb.rename" />
    <child name="rotate" schema="org.gnome.gthumb.rotate" />
    <child name="resize" schema="org.gnome.gthumb.resize" />
    <child name="convert" schema="org.gnome.gthumb.convert" />
    <child name="print" schema="org.gnome.gthumb.print" />
    <child name="crop" schema="org.gnome.gthumb.crop" />
    <child name="import" schema="org.gnome.gthumb.import" />
    <child name="slideshow" schema="org.gnome.gthumb.slideshow" />
  </schema>

  <schema id="org.gnome.gthumb.terminal" path="/org/gnome/gthumb/terminal/" gettext-domain="gthumb">
    <key name="command" type="s">
      <default>'kgx --working-directory=%f'</default>
    </key>
  </schema>

  <enum id="org.gnome.gthumb.GthTextTransform">
    <value nick="none" value="0"/>
    <value nick="lowercase" value="1"/>
    <value nick="uppercase" value="2"/>
  </enum>

  <schema id="org.gnome.gthumb.rename" path="/org/gnome/gthumb/rename/" gettext-domain="gthumb">
    <key name="template" type="s">
      <default>'####%E'</default>
    </key>
    <key name="first-index" type="i">
      <default>1</default>
    </key>
    <key name="sort-name" type="s">
      <default>'Private::Unsorted'</default>
    </key>
    <key name="reverse-order" type="b">
      <default>false</default>
    </key>
    <key name="text-transform" enum="org.gnome.gthumb.GthTextTransform">
      <default>'none'</default>
    </key>
  </schema>

  <enum id="org.gnome.gthumb.GthRotatedSize">
    <value nick="original" value="0"/>
    <value nick="bounding-box" value="1"/>
    <value nick="crop-borders" value="2"/>
  </enum>

  <schema id="org.gnome.gthumb.rotate" path="/org/gnome/gthumb/rotate/" gettext-domain="gthumb">
    <key name="background" type="s">
      <default>'#000'</default>
    </key>
    <key name="size" enum="org.gnome.gthumb.GthRotatedSize">
      <default>'bounding-box'</default>
    </key>
  </schema>

  <enum id="org.gnome.gthumb.GthResizeUnit">
    <value nick="pixel" value="0"/>
    <value nick="percent" value="1"/>
  </enum>

  <schema id="org.gnome.gthumb.resize" path="/org/gnome/gthumb/resize/" gettext-domain="gthumb">
    <key name="width" type="i">
      <default>200</default>
    </key>
    <key name="height" type="i">
      <default>200</default>
    </key>
    <key name="unit" enum="org.gnome.gthumb.GthResizeUnit">
      <default>'pixel'</default>
    </key>
    <key name="keep-aspect-ratio" type="b">
      <default>true</default>
    </key>
    <key name="format" type="s">
      <default>''</default>
    </key>
  </schema>

  <schema id="org.gnome.gthumb.convert" path="/org/gnome/gthumb/convert/" gettext-domain="gthumb">
    <key name="format" type="s">
      <default>''</default>
    </key>
  </schema>

  <enum id="org.gnome.gthumb.GthPrintUnit">
    <value nick="mm" value="0"/>
    <value nick="inch" value="1"/>
  </enum>

  <schema id="org.gnome.gthumb.print" path="/org/gnome/gthumb/print/" gettext-domain="gthumb">
    <key name="rows" type="i">
      <default>1</default>
    </key>
    <key name="columns" type="i">
      <default>1</default>
    </key>
    <key name="unit" enum="org.gnome.gthumb.GthPrintUnit">
      <default>'mm'</default>
    </key>
    <key name="output-dir" type="s">
      <default>''</default>
    </key>
  </schema>

  <schema id="org.gnome.gthumb.crop" path="/org/gnome/gthumb/crop/" gettext-domain="gthumb">
    <key name="custom-ratio" type="d">
      <default>0</default>
    </key>
  </schema>

  <enum id="org.gnome.gthumb.GthAutomaticDate">
    <value nick="today" value="0"/>
    <value nick="modified" value="1"/>
    <value nick="original" value="2"/>
  </enum>

  <schema id="org.gnome.gthumb.import" path="/org/gnome/gthumb/import/" gettext-domain="gthumb">
    <key name="destination" type="s">
      <default>''</default>
    </key>
    <key name="automatic-subfolder" type="b">
      <default>false</default>
    </key>
    <key name="automatic-subfolder-date" enum="org.gnome.gthumb.GthAutomaticDate">
      <default>'original'</default>
    </key>
    <key name="automatic-subfolder-format" type="s">
      <default>'%Y/%m'</default>
    </key>
    <key name="delete-imported" type="b">
      <default>false</default>
    </key>
  </schema>

  <schema id="org.gnome.gthumb.slideshow" path="/org/gnome/gthumb/slideshow/" gettext-domain="gthumb">
    <key name="automatic" type="b">
      <default>true</default>
    </key>
    <key name="delay" type="i">
      <default>5</default>
    </key>
    <key name="random-order" type="b">
      <default>true</default>
    </key>
    <key name="loop" type="b">
      <default>true</default>
    </key>
  </schema>
</schemalist>
