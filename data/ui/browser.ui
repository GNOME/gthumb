<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <template class="GthBrowser">
    <child>
      <object class="AdwOverlaySplitView" id="main_view">
        <property name="min_sidebar_width">200</property>
        <property name="max_sidebar_width">400</property>
        <property name="sidebar_width_fraction">1.0</property>
        <property name="sidebar_width_unit">px</property>
        <!--child>
          <object class="AdwBreakpoint">
            <condition>max-width: 900sp</condition>
            <setter object="main_view" property="collapsed">true</setter>
            <setter object="content_view" property="collapsed">true</setter>
          </object>
        </child-->
        <property name="sidebar">
          <object class="AdwToolbarView">
            <child type="top">
              <object class="AdwHeaderBar">
                <property name="title-widget">
                  <object class="AdwWindowTitle">
                    <property name="title" translatable="yes">Thumbnails</property>
                  </object>
                </property>
                <child type="start">
                  <object class="GtkButton">
                    <property name="icon-name">edit-find-symbolic</property>
                    <property name="action-name">win.find</property>
                  </object>
                </child>
                <child type="end">
                  <object class="GtkMenuButton" id="app_menu_button">
                    <property name="icon-name">open-menu-symbolic</property>
                  </object>
                </child>
              </object>
            </child>
            <property name="content">
              <object class="GtkBox">
                <property name="orientation">vertical</property>
                <child>
                  <object class="GtkBox">
                    <property name="orientation">horizontal</property>
                    <property name="spacing">6</property>
                    <style>
                      <class name="sidebar-header"/>
                    </style>
                    <child>
                      <object class="GtkToggleButton" id="vfs_button">
                        <property name="icon-name">folder-symbolic</property>
                        <property name="action-name">win.show-folders</property>
                        <property name="tooltip-text" translatable="yes">Folders</property>
                        <property name="hexpand">true</property>
                        <style>
                          <class name="flat"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkToggleButton" id="catalog_button">
                        <property name="icon-name">gth-library-symbolic</property>
                        <property name="action-name">win.show-catalogs</property>
                        <property name="tooltip-text" translatable="yes">Catalogs</property>
                        <property name="hexpand">true</property>
                        <style>
                          <class name="flat"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkToggleButton" id="selection_button">
                        <property name="icon-name">gth-flag-symbolic</property>
                        <property name="action-name">win.show-selections</property>
                        <property name="tooltip-text" translatable="yes">Selections</property>
                        <property name="hexpand">true</property>
                        <style>
                          <class name="flat"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkSeparator">
                        <property name="orientation">horizontal</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton">
                        <property name="icon-name">user-home-symbolic</property>
                        <property name="action-name">win.load-home</property>
                        <property name="tooltip-text" translatable="yes">Home Folder</property>
                        <property name="hexpand">true</property>
                        <style>
                          <class name="flat"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkMenuButton">
                        <property name="icon-name">gth-user-bookmarks-symbolic</property>
                        <property name="tooltip-text" translatable="yes">Bookmarks</property>
                        <property name="hexpand">true</property>
                        <style>
                          <class name="flat"/>
                        </style>
                        <property name="popover">
                          <object class="GthActionPopover" id="bookmark_popover">
                          </object>
                        </property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkMenuButton">
                        <property name="icon-name">gth-clock-symbolic</property>
                        <property name="tooltip-text" translatable="yes">History</property>
                        <property name="hexpand">true</property>
                        <style>
                          <class name="flat"/>
                        </style>
                        <property name="popover">
                          <object class="GthActionPopover" id="history_popover">
                          </object>
                        </property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <object class="GthSidebarResizer" id="sidebar_resizer">
                    <child>
                      <object class="GtkStack" id="sidebar_stack">
                        <property name="vexpand">true</property>
                        <child>
                          <object class="GthFolderTree" id="folder_tree">
                            <property name="sidebar">true</property>
                            <property name="single-root">true</property>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </property>
          </object>
        </property>
        <property name="content">
          <object class="AdwToolbarView">
            <child type="top">
              <object class="AdwHeaderBar">
                <property name="title-widget">
                  <object class="GtkMenuButton" id="location_button">
                    <style>
                      <class name="for_toolbar"/>
                      <class name="flat"/>
                    </style>
                    <child>
                      <object class="GtkLabel" id="location_label">
                        <property name="ellipsize">middle</property>
                      </object>
                    </child>
                    <property name="popover">
                      <object class="GtkPopover">
                        <style>
                          <class name="menu"/>
                        </style>
                        <child>
                          <object class="GthActionList" id="location_actions">
                          </object>
                        </child>
                      </object>
                    </property>
                  </object>
                </property>
                <child type="start">
                  <object class="GtkBox">
                    <property name="orientation">horizontal</property>
                    <property name="spacing">6</property>
                    <child>
                      <object class="GtkToggleButton">
                        <property name="icon-name">folder-visiting-symbolic</property>
                        <property name="action-name">win.browser-sidebar</property>
                        <property name="visible">false</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton">
                        <property name="icon-name">go-previous-symbolic</property>
                        <property name="action-name">win.load-previous</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton">
                        <property name="icon-name">go-next-symbolic</property>
                        <property name="action-name">win.load-next</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton">
                        <property name="icon-name">go-up-symbolic</property>
                        <property name="action-name">win.load-parent</property>
                        <style>
                          <class name="flat"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton" id="update_search_button">
                        <property name="icon-name">gth-view-refresh-symbolic</property>
                        <property name="action-name">win.update-search</property>
                        <property name="tooltip-text" translatable="true">Search Again</property>
                        <property name="visible">false</property>
                        <style>
                          <class name="flat"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton" id="update_folder_button">
                        <property name="icon-name">gth-view-refresh-symbolic</property>
                        <property name="action-name">win.reload</property>
                        <property name="tooltip-text" translatable="true">Reload</property>
                        <property name="visible">false</property>
                        <style>
                          <class name="flat"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GthSelectionsStatus" id="selections_status">
                        <property name="margin-start">12</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child type="end">
                  <object class="GtkBox">
                    <property name="orientation">horizontal</property>
                    <property name="spacing">6</property>
                    <child>
                      <object class="GtkButton" id="edit_catalog_button">
                        <property name="icon-name">gth-document-properties-symbolic</property>
                        <property name="action-name">win.edit-catalog</property>
                        <property name="tooltip-text" translatable="true">Catalog Properties</property>
                        <property name="visible">false</property>
                        <style>
                          <class name="flat"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkToggleButton" id="reorder_button">
                        <property name="icon-name">gth-reorder-symbolic</property>
                        <property name="action-name">win.reorder-files</property>
                        <property name="tooltip-text" translatable="true">Reorder Files</property>
                        <property name="visible">false</property>
                        <style>
                          <class name="flat"/>
                        </style>
                      </object>
                    </child>
                    <!--child>
                      <object class="GtkButton">
                        <property name="icon-name">applications-science-symbolic</property>
                        <property name="action-name">win.fake-job</property>
                      </object>
                    </child-->
                    <child>
                      <object class="GtkButton">
                        <property name="icon-name">gth-presentation-symbolic</property>
                        <property name="action-name">win.slideshow</property>
                        <property name="tooltip-text" translatable="true">Presentation</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkToggleButton">
                        <property name="icon-name">gth-info-outline-symbolic</property>
                        <property name="action-name">win.browser-properties-pinned</property>
                        <property name="tooltip-text" translatable="true">File Properties</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkToggleButton">
                        <property name="action-name">win.edit-file</property>
                        <property name="icon-name">gth-paintbrush-symbolic</property>
                        <property name="tooltip-text" translatable="true">Edit Image</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkToggleButton">
                        <property name="icon-name">gth-note-symbolic</property>
                        <property name="action-name">win.edit-metadata</property>
                        <property name="tooltip-text" translatable="true">Edit Comment</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkMenuButton" id="scripts_menu_button">
                        <property name="icon-name">gth-script-symbolic</property>
                        <property name="tooltip-text" translatable="true">Tools</property>
                        <property name="popover">
                          <object class="GthActionPopover" id="tools_popover">
                          </object>
                        </property>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
            <property name="content">
              <object class="AdwOverlaySplitView" id="content_view">
                <property name="min_sidebar_width">200</property>
                <property name="max_sidebar_width">400</property>
                <property name="sidebar_width_fraction">1.0</property>
                <property name="sidebar_width_unit">px</property>
                <property name="sidebar_position">end</property>
                <property name="show_sidebar">false</property>
                <property name="sidebar">
                  <object class="GtkStack" id="second_sidebar_stack">
                    <child>
                      <object class="GthPropertySidebar" id="property_sidebar">
                      </object>
                    </child>
                  </object>
                </property>
                <property name="content">
                  <object class="AdwToolbarView">
                    <property name="content">
                      <object class="GtkStack" id="folder_stack">
                        <property name="vexpand">true</property>
                        <child>
                          <object class="GthFileGrid" id="file_grid">
                            <child>
                              <object class="GtkPopoverMenu" id="file_context_menu">
                                <property name="menu-model">file_menu</property>
                                <property name="has-arrow">true</property>
                                <property name="position">bottom</property>
                                <style>
                                  <class name="deeper"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkPopoverMenu" id="context_menu">
                                <property name="menu-model">current_folder_menu</property>
                                <property name="has-arrow">true</property>
                                <property name="position">bottom</property>
                                <style>
                                  <class name="deeper"/>
                                </style>
                              </object>
                            </child>
                          </object>
                        </child>
                        <child>
                          <object class="AdwStatusPage" id="empty_folder">
                            <style>
                              <class name="view"/>
                            </style>
                            <child>
                              <object class="GthFolderStatus" id="folder_status">
                                <property name="icon-name">gth-content-loading-symbolic</property>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </property>
                    <child type="bottom">
                      <object class="AdwWrapBox">
                        <property name="orientation">horizontal</property>
                        <property name="child-spacing">6</property>
                        <property name="line-spacing">6</property>
                        <style>
                          <class name="statusbar"/>
                        </style>
                        <child>
                          <object class="GthFilterBar" id="filter_bar">
                            <property name="hexpand">true</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkBox">
                            <property name="orientation">horizontal</property>
                            <property name="hexpand">true</property>
                            <property name="halign">end</property>
                            <property name="spacing">12</property>
                            <property name="margin-start">12</property>
                            <child>
                              <object class="GthStatus" id="status">
                              </object>
                            </child>
                            <child>
                              <object class="GtkToggleButton" id="view_properties">
                                <property name="icon-name">gth-left-symbolic</property>
                                <property name="action-name">win.browser-properties-collapsed</property>
                                <property name="tooltip-text" translatable="true">View Properties</property>
                                <style>
                                  <class name="flat"/>
                                </style>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </property>
              </object>
            </property>
          </object>
        </property>
      </object>
    </child>
    <property name="folder_menu">folder_menu</property>
    <property name="catalog_menu">catalog_menu</property>
    <property name="selection_menu">selection_menu</property>
  </template>
  <menu id="file_menu">
    <section>
      <item>
        <attribute name="label" translatable="yes">Open Fullscreen</attribute>
        <attribute name="action">win.view-fullscreen</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">Open in New Window</attribute>
        <attribute name="action">win.view-new-window</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">Open _With…</attribute>
        <attribute name="action">win.open-with</attribute>
      </item>
    </section>
    <section>
      <item>
        <attribute name="label" translatable="yes">Open Folder</attribute>
        <attribute name="action">win.open-container</attribute>
        <attribute name="hidden-when">action-disabled</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">Print</attribute>
        <attribute name="action">win.print</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">Set as Desktop Background</attribute>
        <attribute name="action">win.set-desktop-background</attribute>
      </item>
    </section>
    <section>
      <item>
        <!-- Translators: it's a verb, as in "Cut Files" -->
        <attribute name="label" translatable="yes">Cut</attribute>
        <attribute name="verb-icon">edit-cut-symbolic</attribute>
        <attribute name="action">win.cut-files</attribute>
      </item>
      <item>
        <!-- Translators: it's a verb, as in "Copy Files" -->
        <attribute name="label" translatable="yes">Copy</attribute>
        <attribute name="verb-icon">edit-copy-symbolic</attribute>
        <attribute name="action">win.copy-files</attribute>
      </item>
      <item>
        <!-- Translators: it's a verb, as in "Paste Files" -->
        <attribute name="label" translatable="yes">Paste</attribute>
        <attribute name="verb-icon">edit-paste-symbolic</attribute>
        <attribute name="action">win.paste-files</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">Select All</attribute>
        <attribute name="action">win.file-list-select-all</attribute>
      </item>
    </section>
    <section>
      <item>
        <attribute name="label" translatable="yes">Copy To…</attribute>
        <attribute name="action">win.copy-files-to</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">Move To…</attribute>
        <attribute name="action">win.move-files-to</attribute>
      </item>
      <item>
        <!-- Translators: it's a verb, as in "Rename Files" -->
        <attribute name="label" translatable="yes">Rename</attribute>
        <attribute name="action">win.rename-files</attribute>
      </item>
      <item>
        <!-- Translators: it's a verb, as in "Duplicate Files" -->
        <attribute name="label" translatable="yes">Duplicate</attribute>
        <attribute name="action">win.duplicate-files</attribute>
        <attribute name="hidden-when">action-disabled</attribute>
      </item>
    </section>
    <section>
      <section>
        <item>
          <attribute name="label" translatable="yes">Move to Trash</attribute>
          <attribute name="action">win.trash-files</attribute>
        </item>
        <item>
          <attribute name="label" translatable="yes">Delete</attribute>
          <attribute name="action">win.delete-files-from-disk</attribute>
        </item>
      </section>
    </section>
    <section>
      <section>
        <attribute name="label" translatable="yes">Add to Selection</attribute>
        <attribute name="display-hint">inline-buttons</attribute>
        <item>
          <attribute name="label" translatable="yes">Selection 1</attribute>
          <attribute name="verb-icon">gth-flag-1-symbolic</attribute>
          <attribute name="action">win.add-to-selection</attribute>
          <attribute name="target">1</attribute>
        </item>
        <item>
          <attribute name="label" translatable="yes">Selection 2</attribute>
          <attribute name="verb-icon">gth-flag-2-symbolic</attribute>
          <attribute name="action">win.add-to-selection</attribute>
          <attribute name="target">2</attribute>
        </item>
        <item>
          <attribute name="label" translatable="yes">Selection 3</attribute>
          <attribute name="verb-icon">gth-flag-3-symbolic</attribute>
          <attribute name="action">win.add-to-selection</attribute>
          <attribute name="target">3</attribute>
        </item>
      </section>
      <item>
        <attribute name="label" translatable="yes">Add to Catalog…</attribute>
        <attribute name="action">win.add-to-catalog</attribute>
        <attribute name="hidden-when">action-disabled</attribute>
      </item>
    </section>
    <section>
      <item>
        <attribute name="label" translatable="yes">Remove from Selection</attribute>
        <attribute name="action">win.remove-from-current-selection</attribute>
        <attribute name="hidden-when">action-disabled</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">Remove from Catalog</attribute>
        <attribute name="action">win.remove-from-catalog</attribute>
        <attribute name="hidden-when">action-disabled</attribute>
      </item>
    </section>
  </menu>
  <menu id="current_folder_menu">
    <section>
      <item>
        <attribute name="label" translatable="yes">Open with File Manager</attribute>
        <attribute name="action">win.open-file-manager-here</attribute>
        <attribute name="hidden-when">action-disabled</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">Open in Terminal</attribute>
        <attribute name="action">win.open-terminal-here</attribute>
        <attribute name="hidden-when">action-disabled</attribute>
      </item>
    </section>
    <section>
      <item>
        <!-- Translators: it's a verb, as in "Paste Files" -->
        <attribute name="label" translatable="yes">Paste</attribute>
        <attribute name="action">win.paste-files</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">Select All</attribute>
        <attribute name="action">win.file-list-select-all</attribute>
      </item>
    </section>
  </menu>
  <menu id="folder_menu">
    <section>
      <item>
        <attribute name="label" translatable="yes">Open in New Window</attribute>
        <attribute name="action">folder.open-new-window</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">Open in Terminal</attribute>
        <attribute name="action">folder.open-terminal</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">Open with File Manager</attribute>
        <attribute name="action">folder.open-file-manager</attribute>
      </item>
    </section>
    <section>
      <item>
        <attribute name="label" translatable="yes">Create Folder</attribute>
        <attribute name="action">folder.new</attribute>
      </item>
    </section>
    <section>
      <item>
        <!-- Translators: it's a verb, as in "Cut Files" -->
        <attribute name="label" translatable="yes">Cut</attribute>
        <attribute name="verb-icon">edit-cut-symbolic</attribute>
        <attribute name="action">folder.cut</attribute>
      </item>
      <item>
        <!-- Translators: it's a verb, as in "Copy Files" -->
        <attribute name="label" translatable="yes">Copy</attribute>
        <attribute name="verb-icon">edit-copy-symbolic</attribute>
        <attribute name="action">folder.copy</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">Paste</attribute>
        <attribute name="action">folder.paste</attribute>
      </item>
    </section>
    <section>
      <item>
        <attribute name="label" translatable="yes">Copy To…</attribute>
        <attribute name="action">folder.copy-to</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">Move To…</attribute>
        <attribute name="action">folder.move-to</attribute>
      </item>
      <item>
        <!-- Translators: it's a verb, as in "Rename Files" -->
        <attribute name="label" translatable="yes">Rename</attribute>
        <attribute name="action">folder.rename</attribute>
      </item>
    </section>
    <section>
      <item>
        <attribute name="label" translatable="yes">Move to Trash</attribute>
        <attribute name="action">folder.trash</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">Delete</attribute>
        <attribute name="action">folder.delete-from-disk</attribute>
      </item>
    </section>
  </menu>
  <menu id="catalog_menu">
    <section>
      <item>
        <attribute name="label" translatable="yes">Open in New Window</attribute>
        <attribute name="action">folder.open-new-window</attribute>
      </item>
    </section>
    <section>
      <item>
        <attribute name="label" translatable="yes">New Catalog</attribute>
        <attribute name="action">catalog.new-catalog</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">New Library</attribute>
        <attribute name="action">catalog.new-library</attribute>
      </item>
    </section>
    <section>
      <item>
        <attribute name="label" translatable="yes">Paste</attribute>
        <attribute name="action">folder.paste</attribute>
      </item>
    </section>
    <section>
      <item>
        <attribute name="label" translatable="yes">Rename</attribute>
        <attribute name="action">catalog.rename</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">Move To…</attribute>
        <attribute name="action">catalog.move-to</attribute>
      </item>
    </section>
    <section>
      <item>
        <attribute name="label" translatable="yes">Delete</attribute>
        <attribute name="action">catalog.delete</attribute>
      </item>
    </section>
  </menu>
  <menu id="selection_menu">
    <section>
      <item>
        <attribute name="label" translatable="yes">Open in New Window</attribute>
        <attribute name="action">folder.open-new-window</attribute>
      </item>
    </section>
    <section>
      <item>
        <attribute name="label" translatable="yes">Paste</attribute>
        <attribute name="action">folder.paste</attribute>
      </item>
    </section>
  </menu>
</interface>
