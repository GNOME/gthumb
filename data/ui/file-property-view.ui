<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <template class="GthFilePropertyView">
    <property name="orientation">vertical</property>
    <child>
      <object class="GtkScrolledWindow">
        <property name="hexpand">true</property>
        <property name="vexpand">true</property>
        <child>
          <object class="GtkListView" id="list_view">
            <property name="show_separators">true</property>
            <style>
              <class name="navigation-sidebar"/>
              <class name="property-sidebar"/>
            </style>
          </object>
        </child>
      </object>
    </child>
    <child>
      <object class="GtkPopoverMenu" id="context_menu">
        <style>
          <class name="deeper"/>
        </style>
        <property name="menu-model">property-menu</property>
      </object>
    </child>
  </template>
  <menu id="property-menu">
    <section>
      <item>
        <attribute name="label" translatable="yes">Copy</attribute>
        <attribute name="action">property.copy-value</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">Copy Raw Value</attribute>
        <attribute name="action">property.copy-details</attribute>
      </item>
    </section>
  </menu>
</interface>
