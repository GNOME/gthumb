<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <requires lib="adwaita" version="1.7.0"/>
  <template class="GthFilterBar" parent="GtkBox">
    <property name="orientation">horizontal</property>
    <property name="spacing">12</property>
    <child>
      <object class="GtkMenuButton" id="filter_selector">
        <property name="always_show_arrow">true</property>
        <child>
          <object class="GtkLabel" id="filter_label" />
        </child>
      </object>
    </child>
    <child>
      <object class="GtkBox" id="options_container">
      </object>
    </child>
    <child>
      <object class="GtkButton" id="reset_filter">
        <property name="action-name">filterbar.reset-filter</property>
        <property name="icon-name">window-close-symbolic</property>
        <style>
          <class name="flat"/>
        </style>
      </object>
    </child>
  </template>
</interface>
