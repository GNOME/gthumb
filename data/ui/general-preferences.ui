<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <template class="GthGeneralPreferences">
    <property name="title" translatable="yes">General</property>
    <property name="tag">general</property>
    <property name="child">
      <object class="AdwToolbarView">
        <child type="top">
          <object class="AdwHeaderBar"/>
        </child>
        <property name="content">
          <object class="AdwPreferencesPage">
            <child>
              <object class="AdwPreferencesGroup">
                <child>
                  <object class="AdwSwitchRow" id="open_fullscreen_switch">
                    <property name="title" translatable="yes">Open in Fullscreen Mode</property>
                    <signal name="notify::active" handler="on_fullscreen_activated"/>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </property>
      </object>
    </property>
  </template>
</interface>
