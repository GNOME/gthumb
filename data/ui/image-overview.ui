<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <template class="GthImageOverview">
    <property name="orientation">vertical</property>
    <property name="spacing">12</property>
    <child>
      <object class="GthImageView" id="preview">
        <property name="zoom-type">maximize</property>
        <style>
          <class name="image-view"/>
        </style>
      </object>
    </child>
    <child>
      <object class="GtkBox">
        <property name="orientation">horizontal</property>
        <property name="hexpand">true</property>
        <property name="spacing">12</property>
        <property name="homogeneous">true</property>
        <child>
          <object class="GtkToggleButton">
            <property name="action-name">overview.set-zoom</property>
            <property name="action-target">1.0</property>
            <property name="label" translatable="yes">100%</property>
            <property name="hexpand">true</property>
            <style>
              <class name="smaller-text"/>
              <class name="numeric"/>
            </style>
          </object>
        </child>
        <child>
          <object class="GtkToggleButton">
            <property name="action-name">overview.set-zoom</property>
            <property name="action-target">2.0</property>
            <property name="label" translatable="yes">200%</property>
            <property name="hexpand">true</property>
            <style>
              <class name="smaller-text"/>
              <class name="numeric"/>
            </style>
          </object>
        </child>
        <child>
          <object class="GtkToggleButton">
            <property name="action-name">overview.set-zoom</property>
            <property name="action-target">3.0</property>
            <property name="label" translatable="yes">300%</property>
            <property name="hexpand">true</property>
            <style>
              <class name="smaller-text"/>
              <class name="numeric"/>
            </style>
          </object>
        </child>
      </object>
    </child>
    <child>
      <object class="GtkBox">
        <property name="orientation">horizontal</property>
        <property name="hexpand">true</property>
        <property name="spacing">12</property>
        <property name="homogeneous">true</property>
        <child>
          <object class="GtkToggleButton">
            <property name="action-name">overview.view-all</property>
            <property name="label" translatable="yes">Full Image</property>
            <property name="hexpand">true</property>
            <style>
              <class name="smaller-text"/>
            </style>
          </object>
        </child>
      </object>
    </child>
    <child>
      <object class="GtkScale" id="zoom_scale">
        <property name="adjustment">
          <object class="GtkAdjustment">
            <property name="lower">0</property>
            <property name="upper">100</property>
          </object>
        </property>
      </object>
    </child>
  </template>
</interface>
