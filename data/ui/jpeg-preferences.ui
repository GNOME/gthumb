<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <object class="AdwPreferencesPage" id="page">
    <child>
      <object class="AdwPreferencesGroup">
        <child>
          <object class="AdwActionRow">
            <property name="title" translatable="yes">Quality</property>
            <child type="suffix">
              <object class="GtkScale">
                <property name="adjustment">quality_adjustment</property>
                <property name="digits">0</property>
                <property name="draw-value">false</property>
                <property name="round-digits">1</property>
                <property name="value-pos">left</property>
                <property name="width-request">300</property>
                <marks>
                  <mark value="0" position="bottom" translatable="yes" context="Quality">Low</mark>
                  <mark value="85" position="bottom" />
                  <mark value="100" position="bottom" translatable="yes" context="Quality">High</mark>
                </marks>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="AdwActionRow">
            <property name="title" translatable="yes">Smoothing</property>
            <child type="suffix">
              <object class="GtkScale">
                <property name="adjustment">smoothing_adjustment</property>
                <property name="digits">0</property>
                <property name="draw-value">false</property>
                <property name="round-digits">1</property>
                <property name="value-pos">left</property>
                <property name="width-request">300</property>
                <marks>
                  <mark value="0" position="bottom" />
                </marks>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="AdwSwitchRow" id="optimize">
            <property name="title" translatable="yes">Optimize</property>
          </object>
        </child>
        <child>
          <object class="AdwSwitchRow" id="progressive">
            <property name="title" translatable="yes">Progressive</property>
          </object>
        </child>
      </object>
    </child>
    <child>
      <object class="AdwPreferencesGroup" id="other_preferences">
        <child>
          <object class="AdwComboRow" id="default_extension">
            <property name="title" translatable="yes">Default Extension</property>
            <property name="model">
              <object class="GtkStringList">
                <items>
                  <item>jpeg</item>
                  <item>jpg</item>
                </items>
              </object>
            </property>
          </object>
        </child>
      </object>
    </child>
  </object>
  <object class="GtkAdjustment" id="quality_adjustment">
    <property name="upper">100</property>
    <property name="step-increment">1</property>
    <property name="page-increment">5</property>
    <property name="value">75</property>
  </object>
  <object class="GtkAdjustment" id="smoothing_adjustment">
    <property name="upper">100</property>
    <property name="step-increment">1</property>
    <property name="page-increment">5</property>
    <property name="value">75</property>
  </object>
</interface>
