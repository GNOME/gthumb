<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <requires lib="adwaita" version="1.7.0"/>
  <template class="GthPersonalizeFilters" parent="AdwPreferencesDialog">
    <property name="title" translatable="yes">Filters</property>
    <property name="content_width">700</property>
    <property name="content_height">700</property>
    <child>
      <object class="AdwPreferencesPage">

        <!-- Group: main filter  -->
        <child>
          <object class="AdwPreferencesGroup">
            <child>
              <object class="AdwComboRow" id="general_filter_row">
                <property name="title" translatable="yes">General Filter</property>
                <signal name="notify::selected" handler="on_general_filter_selected"/>
              </object>
            </child>
          </object>
        </child>

        <!-- Group: filters -->
        <child>
          <object class="AdwPreferencesGroup" id="filters_group">
            <property name="title" translatable="yes">Filters</property>
            <property name="header-suffix">
              <object class="GtkButton">
                <style>
                  <class name="flat"/>
                </style>
                <child>
                  <object class="AdwButtonContent">
                    <property name="icon-name">list-add-symbolic</property>
                    <property name="label" translatable="yes">_Add</property>
                    <property name="use-underline">true</property>
                  </object>
                </child>
                <signal name="clicked" handler="on_add_filter" />
              </object>
            </property>
          </object>
        </child>

      </object>
    </child>
  </template>

  <object class="GthFilterEditorPage" id="filter_page">
    <signal name="cancelled" handler="on_cancel_filter" />
    <signal name="save" handler="on_save_filter" />
    <signal name="choose_rule_type" handler="on_choose_rule_type" />
  </object>

  <object class="AdwNavigationPage" id="rule_page">
    <property name="title" translatable="yes">Add Rule</property>
    <child>
      <object class="AdwToolbarView">
        <child type="top">
          <object class="AdwHeaderBar" />
        </child>
        <property name="content">
          <object class="AdwPreferencesPage">
            <child>
              <object class="AdwPreferencesGroup"  id="rule_types">
                <property name="description" translatable="yes">Choose a rule to add to the filter</property>
                <!-- Dynamic content -->
              </object>
            </child>
          </object>
        </property>
      </object>
    </child>
  </object>
</interface>
