<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <object class="AdwPreferencesPage" id="options">
    <child>
      <object class="AdwPreferencesGroup">
        <property name="title" translatable="yes">Pixels</property>
        <child>
          <object class="AdwSpinRow" id="width">
            <property name="title" translatable="yes">Width</property>
          </object>
        </child>
        <child>
          <object class="AdwSpinRow" id="height">
            <property name="title" translatable="yes">Height</property>
          </object>
        </child>
        <child>
          <object class="GtkBox">
            <property name="orientation">vertical</property>
            <child>
              <object class="GtkButton" id="reset_button">
                <property name="label" translatable="yes">_Reset</property>
                <property name="halign">end</property>
                <property name="use-underline">true</property>
                <property name="margin-top">12</property>
                <style>
                  <class name="flat"/>
                </style>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="AdwActionRow">
            <property name="title" translatable="yes">Unit</property>
            <property name="visible">false</property>
            <child type="suffix">
              <object class="AdwToggleGroup" id="unit_group">
                <property name="valign">center</property>
                <child>
                  <object class="AdwToggle">
                    <!-- Translators: pixels as length unit -->
                    <property name="label" translatable="yes" context="Length Unit">px</property>
                    <property name="tooltip" translatable="yes" context="Length Unit">pixels</property>
                    <property name="name">pixels</property>
                  </object>
                </child>
                <child>
                  <object class="AdwToggle">
                    <!-- Translators: percentage as length unit -->
                    <property name="label" translatable="yes" context="Length Unit">%</property>
                    <property name="tooltip" translatable="yes" context="Length Unit">percentage</property>
                    <property name="name">percent</property>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
    <child>
      <object class="AdwPreferencesGroup" id="special_size_group">
        <property name="separate-rows">true</property>
      </object>
    </child>
    <child>
      <object class="AdwPreferencesGroup">
        <property name="title" translatable="yes">Method</property>
        <child>
          <object class="AdwSpinRow" id="restore_session">
            <property name="title" translatable="yes">Scaled</property>
            <property name="activatable">true</property>
            <property name="activatable_widget">method_scaled_check</property>
            <property name="adjustment">zoom_adjustment</property>
            <child type="prefix">
              <object class="GtkCheckButton" id="method_scaled_check">
                <property name="active">true</property>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="AdwActionRow">
            <property name="title" translatable="yes">Repeated</property>
            <property name="activatable">true</property>
            <property name="activatable_widget">method_repeated_check</property>
            <child type="prefix">
              <object class="GtkCheckButton" id="method_repeated_check">
                <property name="group">method_scaled_check</property>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </object>
  <object class="GthImageView" id="image_view">
  </object>
  <object class="AdwNavigationPage" id="more_options_page">
    <property name="title" translatable="yes">Options</property>
    <style>
      <class name="tool-options"/>
    </style>
    <property name="child">
      <object class="AdwToolbarView">
        <child type="top">
          <object class="AdwHeaderBar"/>
        </child>
        <property name="content">
          <object class="AdwPreferencesPage">
            <child>
              <object class="GthAspectRatioGroup" id="aspect_ratio_group">
              </object>
            </child>
            <child>
              <object class="AdwPreferencesGroup">
                <child>
                  <object class="AdwSwitchRow" id="high_quality_switch">
                    <property name="title" translatable="yes">High Quality</property>
                    <property name="active">true</property>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </property>
      </object>
    </property>
  </object>
  <object class="GtkBox" id="action_bar">
    <property name="orientation">horizontal</property>
    <property name="spacing">6</property>
    <property name="halign">end</property>
    <style>
      <class name="smaller-text"/>
    </style>
    <child>
      <object class="GtkButton" id="more_options">
        <child>
          <object class="GtkBox">
            <property name="orientation">horizontal</property>
            <property name="spacing">6</property>
            <child>
              <object class="GtkLabel">
                <property name="label" translatable="yes">Options</property>
              </object>
            </child>
            <child>
              <object class="GtkImage">
                <property name="icon-name">go-next-symbolic</property>
              </object>
            </child>
          </object>
        </child>
        <style>
          <class name="flat"/>
        </style>
      </object>
    </child>
  </object>
  <object class="GtkAdjustment" id="zoom_adjustment">
    <property name="lower">5</property>
    <property name="upper">500</property>
    <property name="step_increment">1</property>
    <property name="page_increment">10</property>
    <property name="value">100</property>
  </object>
</interface>
