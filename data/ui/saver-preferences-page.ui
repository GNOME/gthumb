<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <template class="GthSaverPreferencesPage">
    <property name="tag">saver-options</property>
    <property name="child">
      <object class="AdwToolbarView" id="toolbar_view">
        <child type="top">
          <object class="AdwHeaderBar" />
        </child>
      </object>
    </property>
  </template>
</interface>
