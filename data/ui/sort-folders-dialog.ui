<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <template class="GthSortFoldersDialog">
    <property name="title" translatable="yes">Sort Folders</property>
    <property name="content_width">500</property>
    <child>
      <object class="AdwPreferencesPage">
        <child>
          <object class="AdwPreferencesGroup" id="rule_types">
            <!-- Dynamic content -->
          </object>
        </child>
        <child>
          <object class="AdwPreferencesGroup">
            <child>
              <object class="AdwSwitchRow" id="inverse_order_switch">
                <property name="title" translatable="yes">Reverse Order</property>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </template>
</interface>
