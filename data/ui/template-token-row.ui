<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <template class="GthTemplateTokenRow">
    <property name="activatable">false</property>
    <child>
      <object class="GtkGrid">
        <property name="margin-start">12</property>
        <property name="margin-end">6</property>
        <property name="margin-top">6</property>
        <property name="margin-bottom">6</property>
        <child>
          <object class="GtkBox" id="prefix">
            <layout>
              <property name="column">0</property>
              <property name="row">0</property>
            </layout>
            <property name="valign">center</property>
            <property name="margin-end">12</property>
            <child>
              <object class="GtkImage">
                <property name="icon-name">list-drag-handle-symbolic</property>
                <property name="opacity">0.5</property>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkBox" id="title_box">
            <layout>
              <property name="column">1</property>
              <property name="row">0</property>
            </layout>
            <property name="orientation">horizontal</property>
            <property name="spacing">6</property>
            <property name="valign">center</property>
            <property name="halign">fill</property>
            <property name="hexpand">true</property>
            <property name="margin-end">24</property>
            <child>
              <object class="GtkLabel" id="title">
              </object>
            </child>
            <child>
              <object class="GtkBox" id="edit_value_box">
                <property name="orientation">horizontal</property>
                <property name="visible">false</property>
                <style>
                  <class name="linked"/>
                </style>
                <child>
                  <object class="GtkEntry" id="value">
                    <property name="hexpand">true</property>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="edit_value_button">
                    <property name="icon-name">gth-edit-item-symbolic</property>
                    <property name="action-name">row.edit-entry</property>
                    <property name="action-target">'value'</property>
                    <property name="visible">false</property>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="hide_value_button">
                    <property name="icon-name">edit-undo</property>
                    <property name="visible">false</property>
                    <property name="action-name">row.hide-value</property>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="GtkDropDown" id="date_format">
                <property name="visible">false</property>
              </object>
            </child>
            <child>
              <object class="GtkDropDown" id="attribute_selector">
                <property name="visible">false</property>
                <property name="enable-search">true</property>
                <property name="search-match-mode">substring</property>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkBox" id="suffix">
            <layout>
              <property name="column">2</property>
              <property name="row">0</property>
            </layout>
            <property name="orientation">horizontal</property>
            <property name="valign">center</property>
            <property name="halign">end</property>
            <property name="spacing">6</property>
            <child>
              <object class="GtkMenuButton">
                <property name="valign">center</property>
                <property name="margin-start">6</property>
                <property name="icon-name">view-more-symbolic</property>
                <property name="menu-model">row-menu</property>
                <style>
                  <class name="flat"/>
                  <class name="circular"/>
                </style>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkBox" id="extra_content">
            <layout>
              <property name="column">1</property>
              <property name="row">1</property>
            </layout>
            <property name="orientation">vertical</property>
            <property name="spacing">6</property>
            <property name="margin-top">6</property>
            <property name="margin-bottom">6</property>
            <property name="margin-end">24</property>
            <property name="visible">false</property>
            <child>
              <object class="GtkBox">
                <property name="orientation">horizontal</property>
                <style>
                  <class name="linked"/>
                </style>
                <child>
                  <object class="GtkEntry" id="prompt">
                    <property name="hexpand">true</property>
                    <property name="placeholder-text" translatable="yes">Title</property>
                  </object>
                </child>
                <child>
                  <object class="GtkButton">
                    <property name="icon-name">gth-edit-item-symbolic</property>
                    <property name="action-name">row.edit-entry</property>
                    <property name="action-target">'prompt'</property>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="GtkBox">
                <property name="orientation">horizontal</property>
                <style>
                  <class name="linked"/>
                </style>
                <child>
                  <object class="GtkEntry" id="default_value">
                    <property name="hexpand">true</property>
                    <property name="placeholder-text" translatable="yes">Default Value</property>
                  </object>
                </child>
                <child>
                  <object class="GtkButton">
                    <property name="icon-name">gth-edit-item-symbolic</property>
                    <property name="action-name">row.edit-entry</property>
                    <property name="action-target">'default-value'</property>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </template>
  <menu id="row-menu">
    <section>
      <item>
        <attribute name="label" translatable="yes">Add</attribute>
        <attribute name="action">row.add</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">Delete</attribute>
        <attribute name="action">row.delete</attribute>
      </item>
    </section>
    <section>
      <item>
        <attribute name="label" translatable="yes">Move to Top</attribute>
        <attribute name="action">row.move-to-top</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">Move to Bottom</attribute>
        <attribute name="action">row.move-to-bottom</attribute>
      </item>
    </section>
  </menu>
</interface>
