<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <template class="GthViewerPreferences">
    <property name="title" translatable="yes">Images</property>
    <property name="tag">viewer</property>
    <property name="child">
      <object class="AdwToolbarView">
        <child type="top">
          <object class="AdwHeaderBar"/>
        </child>
        <property name="content">
          <object class="AdwPreferencesPage">
            <child>
              <object class="AdwPreferencesGroup">
                <child>
                  <object class="AdwComboRow" id="scroll_action">
                    <property name="title" translatable="yes">Scroll Action</property>
                    <signal name="notify::selected" handler="on_scroll_action_selected"/>
                    <property name="model">
                      <object class="GtkStringList">
                        <items>
                          <item translatable="yes">Change Zoom</item>
                          <item translatable="yes">Change File</item>
                        </items>
                      </object>
                    </property>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </property>
      </object>
    </property>
  </template>
</interface>
