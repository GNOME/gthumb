<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <template class="GthViewerStatus">
    <property name="orientation">horizontal</property>
    <property name="spacing">0</property>
    <style>
      <class name="statusbar"/>
      <class name="floating"/>
    </style>
    <child>
      <object class="GtkBox">
        <style>
          <class name="linked"/>
        </style>
        <child>
          <object class="GtkButton">
            <property name="action-name">win.view-previous</property>
            <style>
              <class name="flat"/>
            </style>
            <child>
              <object class="GtkImage">
                <!--property name="icon-size">large</property-->
                <property name="icon-name">left-symbolic</property>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkButton">
            <property name="action-name">win.view-next</property>
            <style>
              <class name="flat"/>
            </style>
            <child>
              <object class="GtkImage">
                <!--property name="icon-size">large</property-->
                <property name="icon-name">right-symbolic</property>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
    <child>
      <object class="GtkBox">
        <property name="spacing">24</property>
        <property name="margin-start">24</property>
        <property name="margin-end">24</property>
        <child>
          <object class="GtkBox">
            <property name="orientation">horizontal</property>
            <property name="spacing">0</property>
            <child>
              <object class="GtkLabel" id="file_position">
                <style>
                  <class name="numeric"/>
                </style>
              </object>
            </child>
            <child>
              <object class="GtkLabel" id="total_files">
                <style>
                  <class name="numeric"/>
                  <class name="dimmed"/>
                </style>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkLabel" id="pixel_info">
            <style>
              <class name="numeric"/>
            </style>
          </object>
        </child>
        <child>
          <object class="GtkLabel" id="zoom_info">
            <style>
              <class name="numeric"/>
            </style>
          </object>
        </child>
      </object>
    </child>
    <child>
      <object class="GtkBox" id="viewer_tools">
        <property name="spacing">24</property>
        <property name="visible">false</property>
        <style>
          <class name="statusbar-section"/>
        </style>
      </object>
    </child>
    <child>
      <object class="AdwSpinner" id="spinner">
        <property name="visible">false</property>
        <property name="valign">center</property>
      </object>
    </child>
  </template>
</interface>
