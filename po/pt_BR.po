#: data/org.gnome.gthumb-devel.desktop.in:2 data/org.gnome.gthumb.desktop.in:2
#: data/ui/browser.ui:23 data/ui/main-window.ui:4 data/ui/slideshow-window.ui:4
msgid "Thumbnails"
msgstr "Miniaturas"

#: data/appdata/org.gnome.gthumb.metainfo.xml.in:15
#: data/org.gnome.gthumb-devel.desktop.in:3 data/org.gnome.gthumb.desktop.in:3
msgid "View and organize your images"
msgstr "Veja e organize as suas imagens"

#: data/appdata/org.gnome.gthumb.metainfo.xml.in:20
msgid "Image viewer, editor, browser and organizer."
msgstr "Visualizador, editor, navegador e organizador de imagens."

#: data/appdata/org.gnome.gthumb.metainfo.xml.in:23
msgid "View images: PNG, JPEG, WEBP, SVG, JXL, HEIF, AVIF, TIFF, GIF, RAW."
msgstr "Veja imagens: PNG, JPEG, WEBP, SVG, JXL, HEIF, AVIF, TIFF, GIF, RAW."

#: data/appdata/org.gnome.gthumb.metainfo.xml.in:26
msgid ""
"Edit images: scale, rotate and crop images, change contrast, brightness and "
"saturation, as well as other color transformations."
msgstr ""
"Editar imagens: ajustar, girar e recortar imagens; alterar a saturação, o "
"brilho, o contraste, bem como outras transformações de cores."

#: data/appdata/org.gnome.gthumb.metainfo.xml.in:29
msgid "View and edit embedded metadata: EXIF, IPTC and XMP."
msgstr "Veja e edite metadados embutidos: EXIF, IPTC e XMP."

# "script" não foi traduzido para "roteiro" porque se trata de pequenos programas com automações para serem executadas sobre um dado arquivo. Preferi deixar entre parênteses para que o leitor da mensagem entenda melhor o contexto.
#: data/appdata/org.gnome.gthumb.metainfo.xml.in:32
msgid ""
"File manager operations: copy, move, rename and delete files and folders, "
"execute scripts on the selected files."
msgstr ""
"Operações de gestão de arquivos: copiar, mover, renomear e deletar arquivos "
"e pastas, executar automações (scripts) nos arquivos selecionados."

#: data/appdata/org.gnome.gthumb.metainfo.xml.in:35
msgid "Image specific tools:"
msgstr "Ferramentas específicas para imagens:"

#: data/appdata/org.gnome.gthumb.metainfo.xml.in:39
msgid "JPEG lossless transformations"
msgstr "Transformações JPEG sem perdas (lossless)"

#: data/appdata/org.gnome.gthumb.metainfo.xml.in:40
msgid "Image resize"
msgstr "Redimensionar imagem"

#: data/appdata/org.gnome.gthumb.metainfo.xml.in:41
msgid "Format conversion"
msgstr "Conversão de formato"

#: data/appdata/org.gnome.gthumb.metainfo.xml.in:42
msgid "Slideshow"
msgstr "Apresentação de slides"

# Descrição de extensão - ponto final acrescentado propositalmente.
#: data/appdata/org.gnome.gthumb.metainfo.xml.in:43
msgid "Setting an image as desktop background"
msgstr "Define a imagem como plano de fundo da área de trabalho"

#: data/appdata/org.gnome.gthumb.metainfo.xml.in:45
#, fuzzy
#| msgid ""
#| "As an image organizer gThumb allows to add comments and other metadata to "
#| "images; organize images in catalogs and catalogs in libraries; search for "
#| "images and save the result as a catalog."
msgid ""
"Add comments and other metadata to images, organize images in catalogs and "
"catalogs in libraries, search for images and save the result as a catalog."
msgstr ""
"Como um organizador de imagens o gThumb permite adicionar comentários e "
"outros metadados nas imagens; organiza imagens em catálogos e catálogos em "
"bibliotecas; pesquisa por imagens e salva o resultado como um catálogo."

